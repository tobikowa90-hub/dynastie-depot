# OneDrive temp files
.tmp.drivedownload/
.tmp.driveupload/
~$*

# Archive (historisch, nicht fuer Remote Agent relevant)
# Pattern mit /* statt /, damit Whitelist-Exceptions fuer JSONL greifen koennen
05_Archiv/*

# Exception: Backtest-Ready JSONL-Archive MUESSEN git-tracked sein (Spec §3 append-only)
!05_Archiv/score_history.jsonl
!05_Archiv/flag_events.jsonl

# Skill-Pakete (ZIPs, nicht fuer Remote Agent)
06_Skills-Pakete/

# Superpowers docs (nur lokal relevant)
docs/superpowers/

# Lock files (LibreOffice/Excel)
.~lock.*

# OS files
Thumbs.db
.DS_Store
desktop.ini

# Claude Code personal settings (per-user permissions, not for remote agents)
.claude/settings.local.json

# Python bytecode cache
__pycache__/
*.pyc

# Backtest-Ready ephemere Draft-Handoffs (Skill backtest-ready-forward-verify)
03_Tools/backtest-ready/_drafts/*.json
